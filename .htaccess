# Repo docs (README.md, CLAUDE.md) deploy with the site but aren't pages — return 403.
<FilesMatch "\.md$">
  Require all denied
</FilesMatch>

# CSS/JS: always revalidate so visitors get fresh files right after a deploy.
# (Files are tiny; the ETag/304 round-trip is negligible.)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Images/fonts can cache long — they rarely change.
  <FilesMatch "\.(svg|png|jpg|jpeg|webp|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
